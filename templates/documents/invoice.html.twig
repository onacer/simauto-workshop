{% extends 'base.html.twig' %}

{% set doc_no = operation.document_no|default(operation.invoice_no) %}

{% block title %}{{ doc_no }} - SIM Auto{% endblock %}

{% block body %}
<main class="document-page">
    <div class="doc-actions">
        <a class="btn btn-dark" href="{{ path('app_dashboard') }}">Accueil</a>
        {% if operation.doc_type == 'invoice' %}
            <a class="btn btn-primary" href="{{ path('app_receipt', {id: operation.id}) }}">Receipt</a>
        {% endif %}
        {% if operation.doc_type == 'quote' and operation.status == 'draft' %}
            <form method="post" action="{{ path('app_document_confirm', {id: operation.id}) }}" class="inline-form"><button class="btn btn-primary" type="submit">Confirmer</button></form>
            <form method="post" action="{{ path('app_document_invoice', {id: operation.id}) }}" class="inline-form"><button class="btn btn-primary" type="submit">Facturer</button></form>
        {% elseif operation.doc_type == 'order' and operation.status == 'draft' %}
            <form method="post" action="{{ path('app_document_invoice', {id: operation.id}) }}" class="inline-form"><button class="btn btn-primary" type="submit">Facturer</button></form>
        {% endif %}
        <button class="btn btn-primary" onclick="window.print()">Imprimer</button>
    </div>

    {% include 'documents/_operation_doc.html.twig' with {operation: operation, company: company, amount_words: amount_words} %}
</main>
{% endblock %}
