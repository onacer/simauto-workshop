{% extends 'base.html.twig' %}
{% block title %}{{ 'suppliers.title'|trans }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>{{ 'suppliers.title'|trans }}</h1><a class="btn btn-dark" href="{{ path('app_dashboard') }}">{{ 'ui.back'|trans }}</a></section>
    {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message|trans }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message|trans }}</div>{% endfor %}
    <section class="panel">
        <form method="post" class="form-grid">
            <label>{{ 'ui.name'|trans }}<input name="name" required></label>
            <label>{{ 'ui.phone'|trans }}<input name="phone"></label>
            <label>{{ 'ui.email'|trans }}<input name="email" type="email"></label>
            <label>ICE<input name="ice"></label>
            <label>{{ 'ui.address'|trans }}<input name="address"></label>
            <button class="btn btn-primary" type="submit">{{ 'ui.save'|trans }}</button>
        </form>
    </section>
    <section class="panel">
        <label class="list-live-search">{{ 'ui.search'|trans }}<input type="search" data-live-search data-live-target="#suppliers-table" placeholder="{{ 'suppliers.supplier'|trans }}"></label>
        <div class="data-table" id="suppliers-table">
            <div class="table-head"><span>{{ 'suppliers.supplier'|trans }}</span><span>{{ 'ui.phone'|trans }}</span><span>ICE</span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for supplier in suppliers %}
                <div data-live-row data-search="{{ (supplier.name ~ ' ' ~ supplier.phone ~ ' ' ~ supplier.email ~ ' ' ~ supplier.ice)|lower }}">
                    <strong>{{ supplier.name }}</strong>
                    <span>{{ supplier.phone }}</span>
                    <span>{{ supplier.ice }}</span>
                    <span class="row-actions">
                        <a href="{{ path('app_supplier_show', {id: supplier.id}) }}">{{ 'ui.show'|trans }}</a>
                        {% if can('edit', user) %}<a href="{{ path('app_supplier_edit', {id: supplier.id}) }}">{{ 'ui.edit'|trans }}</a>{% endif %}
                        {% if can('toggle', user) %}
                            {% if supplier.active|default(1) == 1 %}
                                <form class="inline-form" method="post" action="{{ path('app_record_state', {entity: 'supplier', id: supplier.id, action: 'deactivate'}) }}">
                                    <input type="hidden" name="_token" value="{{ record_token|default('') }}">
                                    <button type="submit">{{ 'ui.deactivate'|trans }}</button>
                                </form>
                            {% else %}
                                <form class="inline-form" method="post" action="{{ path('app_record_state', {entity: 'supplier', id: supplier.id, action: 'reactivate'}) }}">
                                    <input type="hidden" name="_token" value="{{ record_token|default('') }}">
                                    <button type="submit">{{ 'ui.activate'|trans }}</button>
                                </form>
                            {% endif %}
                        {% endif %}
                        {% if can('delete', user) %}
                            <form class="inline-form" method="post" action="{{ path('app_record_state', {entity: 'supplier', id: supplier.id, action: 'delete'}) }}" onsubmit="return confirm('{{ 'ui.confirm_delete'|trans|e('js') }}')">
                                <input type="hidden" name="_token" value="{{ record_token|default('') }}">
                                <button type="submit">{{ 'ui.delete'|trans }}</button>
                            </form>
                        {% endif %}
                    </span>
                </div>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
