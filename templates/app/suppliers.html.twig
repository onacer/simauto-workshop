{% extends 'base.html.twig' %}
{% block title %}الموردون - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>الموردون</h1><a class="btn btn-dark" href="{{ path('app_dashboard') }}">رجوع</a></section>
    {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message }}</div>{% endfor %}
    <section class="panel">
        <form method="post" class="form-grid">
            <label>الاسم<input name="name" required></label>
            <label>الهاتف<input name="phone"></label>
            <label>البريد<input name="email" type="email"></label>
            <label>ICE<input name="ice"></label>
            <label>العنوان<input name="address"></label>
            <button class="btn btn-primary" type="submit">حفظ</button>
        </form>
    </section>
    <section class="panel">
        <div class="data-table">
            <div class="table-head"><span>المورد</span><span>الهاتف</span><span>ICE</span><span>إجراءات</span></div>
            {% for supplier in suppliers %}
                <div>
                    <strong>{{ supplier.name }}</strong>
                    <span>{{ supplier.phone }}</span>
                    <span>{{ supplier.ice }}</span>
                    <span class="row-actions">
                        <a href="{{ path('app_supplier_edit', {id: supplier.id}) }}">تعديل</a>
                        {% if can('delete', user) %}
                            <form method="post" action="{{ path('app_supplier_deactivate', {id: supplier.id}) }}"><button class="link-button">تعطيل</button></form>
                        {% endif %}
                    </span>
                </div>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
