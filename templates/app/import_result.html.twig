{% extends 'base.html.twig' %}

{% block title %}{{ 'import.result'|trans }} - SIM Auto{% endblock %}

{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}

<main class="main-board">
    <section class="page-head">
        <h1>{{ 'import.result'|trans }}</h1>
        <a class="btn btn-dark" href="{{ path('app_import') }}">{{ 'ui.back'|trans }}</a>
    </section>

    {% if error %}
        <div class="alert alert-error">{{ error|trans }}</div>
    {% endif %}

    {% if report %}
        <section class="home-grid import-summary">
            <div class="home-card tone-yellow"><span>01</span><strong>{{ report.processed }}</strong><small>{{ 'import.processed'|trans }}</small></div>
            <div class="home-card tone-gold"><span>02</span><strong>{{ report.created }}</strong><small>{{ 'import.created'|trans }}</small></div>
            <div class="home-card tone-black"><span>03</span><strong>{{ report.updated }}</strong><small>{{ 'import.updated'|trans }}</small></div>
            <div class="home-card tone-red"><span>04</span><strong>{{ report.ignored }}</strong><small>{{ 'import.ignored'|trans }}</small></div>
        </section>

        <section class="panel">
            <h2>{{ 'ui.errors'|trans }}</h2>
            {% if report.errors %}
                <div class="data-table">
                    <div class="table-head"><span>{{ 'ui.line'|trans }}</span><span>{{ 'ui.column'|trans }}</span><span>{{ 'ui.message'|trans }}</span><span></span></div>
                    {% for error in report.errors %}
                        <div>
                            <strong>{{ error.line }}</strong>
                            <span>{{ error.column }}</span>
                            <span>{{ error.message }}</span>
                            <span></span>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="empty-state">{{ 'import.no_errors'|trans }}</p>
            {% endif %}
        </section>
    {% endif %}
</main>
{% endblock %}
