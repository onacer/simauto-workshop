{% extends 'base.html.twig' %}

{% block title %}{{ 'users.change_password'|trans }} - SIM Auto{% endblock %}

{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}

<main class="main-board">
    <section class="page-head">
        <h1>{{ 'users.change_password'|trans }}</h1>
        <a class="btn btn-dark" href="{{ self_change ? path('app_dashboard') : path('app_users') }}">{{ 'ui.back'|trans }}</a>
    </section>

    {% if error %}
        <div class="alert alert-error">{{ error|trans }}</div>
    {% endif %}

    <section class="panel">
        <form class="form-grid" method="post">
            <input type="hidden" name="_token" value="{{ token }}">

            <label>
                {{ 'users.user'|trans }}
                <input value="{{ target.name }} - {{ target.email }}" disabled>
            </label>

            {% if self_change %}
                <label>
                    {{ 'users.current_password'|trans }}
                    <input type="password" name="old_password" required>
                </label>
            {% endif %}

            <label>
                {{ 'users.new_password'|trans }}
                <input type="password" name="password" minlength="8" required>
            </label>

            <label>
                {{ 'users.confirm_password'|trans }}
                <input type="password" name="password_confirm" minlength="8" required>
            </label>

            <button class="btn btn-primary" type="submit">{{ 'ui.save'|trans }}</button>
        </form>
    </section>
</main>
{% endblock %}
