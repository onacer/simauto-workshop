{% extends 'base.html.twig' %}

{% block title %}{{ 'operations.history.title'|trans }} - SIM Auto{% endblock %}

{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}

<main class="main-board">
    <section class="page-head">
        <h1>{{ 'operations.history.title'|trans }}</h1>
        <a class="btn btn-dark" href="{{ path('app_operations') }}">{{ 'ui.back'|trans }}</a>
    </section>

    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning">{{ message|trans }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message|trans }}</div>
    {% endfor %}

    <section class="panel">
        <form method="get" class="form-grid history-filters">
            <label>{{ 'operations.history.search'|trans }}
                <input name="q" value="{{ filters.q }}" placeholder="{{ 'operations.history.search_placeholder'|trans }}">
            </label>
            <label>{{ 'operations.history.doc_type'|trans }}
                <select name="doc_type">
                    <option value="">{{ 'ui.all'|trans }}</option>
                    <option value="quote" {{ filters.doc_type == 'quote' ? 'selected' : '' }}>{{ 'documents.type.quote'|trans }}</option>
                    <option value="order" {{ filters.doc_type == 'order' ? 'selected' : '' }}>{{ 'documents.type.order'|trans }}</option>
                    <option value="invoice" {{ filters.doc_type == 'invoice' ? 'selected' : '' }}>{{ 'documents.type.invoice'|trans }}</option>
                </select>
            </label>
            <label>{{ 'reports.date_from'|trans }}<input type="date" name="from" value="{{ filters.from }}"></label>
            <label>{{ 'reports.date_to'|trans }}<input type="date" name="to" value="{{ filters.to }}"></label>
            <label>{{ 'operations.payment'|trans }}
                <select name="payment">
                    <option value="">{{ 'ui.all'|trans }}</option>
                    {% for method in ['ESP', 'CHQ', 'CB', 'VIR'] %}
                        <option value="{{ method }}" {{ filters.payment == method ? 'selected' : '' }}>{{ ('payment.code.' ~ method)|trans }}</option>
                    {% endfor %}
                </select>
            </label>
            <button class="btn btn-primary" type="submit">{{ 'operations.history.submit'|trans }}</button>
            <a class="btn btn-dark" href="{{ path('app_operations_history') }}">{{ 'operations.history.reset'|trans }}</a>
        </form>
    </section>

    <section class="panel">
        <div class="panel-title-row">
            <h2>{{ 'operations.history.results'|trans({'%count%': result_total}) }}</h2>
            {% if is_limited %}<small class="badge badge-disabled">{{ 'operations.history.limit'|trans }}</small>{% endif %}
        </div>
        <div class="data-table operation-history-table">
            <div class="table-head">
                <span>{{ 'ui.type'|trans }}</span>
                <span>N°</span>
                <span>{{ 'ui.date'|trans }}</span>
                <span>{{ 'ui.client'|trans }}</span>
                <span>{{ 'vehicles.vehicle'|trans }}</span>
                <span>{{ 'operations.payment'|trans }}</span>
                <span>{{ 'operations.total_ttc'|trans }}</span>
                <span>{{ 'ui.actions'|trans }}</span>
            </div>
            {% for operation in operations %}
                <div>
                    <span>{% include 'app/_doc_badge.html.twig' with {type: operation.doc_type} %}</span>
                    <strong>{{ operation.document_no }}</strong>
                    <span>{{ operation.created_at|date('d/m/Y H:i') }}</span>
                    <span>{{ operation.client_name }}</span>
                    <span>{{ operation.vehicle_plate }}</span>
                    <span>{{ ('payment.code.' ~ operation.payment_method)|trans }}</span>
                    <span>{{ operation.total_ttc|number_format(2, ',', ' ') }} DH</span>
                    <span class="row-actions">
                        <a href="{{ path('app_operation_show', filters|merge({id: operation.id})) }}">{{ 'ui.show'|trans }}</a>
                        <a href="{{ path('app_document', {id: operation.id}) }}" target="_blank" rel="noopener">{{ 'documents.print'|trans }}</a>
                        {% if operation.doc_type == 'invoice' %}
                            <a href="{{ path('app_receipt', {id: operation.id}) }}">{{ 'billing.receipt'|trans }}</a>
                        {% endif %}
                    </span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'operations.history.empty'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
