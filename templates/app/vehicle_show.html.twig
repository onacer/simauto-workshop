{% extends 'base.html.twig' %}
{% block title %}{{ vehicle.plate }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head">
        <h1>{{ vehicle.plate }}</h1>
        <span class="row-actions">
            {% include 'app/_action_button.html.twig' with {
                label: 'ui.edit'|trans,
                url: path('app_vehicle_edit', {id: vehicle.id}),
                active: can('edit.reference', user),
                class: 'btn btn-primary',
                reason: 'access.admin_only'|trans
            } only %}
            <a class="btn btn-dark" href="{{ path('app_vehicles') }}">{{ 'ui.back'|trans }}</a>
        </span>
    </section>

    {% include 'app/_show_info.html.twig' with {rows: [
        {label: 'vehicles.owner'|trans, value: vehicle.client_name},
        {label: 'ui.phone'|trans, value: vehicle.client_phone},
        {label: 'vehicles.brand'|trans, value: vehicle.brand_name},
        {label: 'vehicles.model'|trans, value: vehicle.model_name},
        {label: 'vehicles.year'|trans, value: vehicle.year},
        {label: 'vehicles.mileage'|trans, value: vehicle.mileage},
        {label: 'vehicles.notes'|trans, value: vehicle.notes},
        {label: 'ui.created_at'|trans, value: vehicle.created_at}
    ]} %}

    <section class="panel">
        <h2>{{ 'clients.owner'|trans }}</h2>
        <div class="row-actions">
            <a href="{{ path('app_client_show', {id: vehicle.client_id}) }}">{{ 'clients.show_card'|trans }}</a>
        </div>
    </section>

    <section class="panel">
        <h2>{{ 'vehicles.history'|trans }}</h2>
        <div class="data-table">
            <div class="table-head"><span>{{ 'ui.date'|trans }}</span><span>{{ 'billing.invoice'|trans }}</span><span>{{ 'ui.client'|trans }}</span><span>{{ 'ui.amount'|trans }}</span></div>
            {% for operation in operations %}
                <div>
                    <strong>{{ operation.created_at|date('d/m/Y') }}</strong>
                    <span><a href="{{ path('app_operation_show', {id: operation.id}) }}">{{ operation.document_no|default(operation.invoice_no) }}</a></span>
                    <span>{{ operation.client_real_name ?: operation.client_name }}</span>
                    <span>{{ operation.total|number_format(2, ',', ' ') }} DH</span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'vehicles.no_operations'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
