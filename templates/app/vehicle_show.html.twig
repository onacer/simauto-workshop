{% extends 'base.html.twig' %}
{% block title %}{{ vehicle.plate }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head">
        <h1>{{ vehicle.plate }}</h1>
        <span class="row-actions">
            <a class="btn btn-dark" href="{{ path('app_vehicles') }}">رجوع</a>
        </span>
    </section>

    {% include 'app/_show_info.html.twig' with {rows: [
        {label: 'المالك', value: vehicle.client_name},
        {label: 'الهاتف', value: vehicle.client_phone},
        {label: 'الماركة', value: vehicle.brand_name},
        {label: 'الموديل', value: vehicle.model_name},
        {label: 'السنة', value: vehicle.year},
        {label: 'الكيلومترات', value: vehicle.mileage},
        {label: 'ملاحظات', value: vehicle.notes},
        {label: 'تاريخ الإنشاء', value: vehicle.created_at}
    ]} %}

    <section class="panel">
        <h2>العميل المالك</h2>
        <div class="row-actions">
            <a href="{{ path('app_client_show', {id: vehicle.client_id}) }}">عرض بطاقة العميل</a>
        </div>
    </section>

    <section class="panel">
        <h2>تاريخ العمليات</h2>
        <div class="data-table">
            <div class="table-head"><span>التاريخ</span><span>الفاتورة</span><span>العميل</span><span>المبلغ</span></div>
            {% for operation in operations %}
                <div>
                    <strong>{{ operation.created_at|date('d/m/Y') }}</strong>
                    <span><a href="{{ path('app_invoice', {id: operation.id}) }}">{{ operation.document_no|default(operation.invoice_no) }}</a></span>
                    <span>{{ operation.client_real_name ?: operation.client_name }}</span>
                    <span>{{ operation.total|number_format(2, ',', ' ') }} DH</span>
                </div>
            {% else %}
                <p class="empty-state">لا توجد عمليات لهذه السيارة.</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
