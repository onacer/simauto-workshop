{% extends 'base.html.twig' %}

{% block title %}{{ (mode == 'new' ? 'users.new' : 'users.edit')|trans }} - SIM Auto{% endblock %}

{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}

<main class="main-board">
    <section class="page-head">
        <h1>{{ (mode == 'new' ? 'users.new' : 'users.edit')|trans }}</h1>
        <a class="btn btn-dark" href="{{ path('app_users') }}">{{ 'ui.back'|trans }}</a>
    </section>

    {% if error %}
        <div class="alert alert-error">{{ error|trans }}</div>
    {% endif %}

    <section class="panel">
        <form class="form-grid" method="post">
            <input type="hidden" name="_token" value="{{ token }}">

            <label>
                {{ 'ui.name'|trans }}
                <input name="name" value="{{ form.name|default('') }}" required>
            </label>

            <label>
                {{ 'ui.email'|trans }}
                <input type="email" name="email" value="{{ form.email|default('') }}" required>
            </label>

            <label>
                {{ 'users.role'|trans }}
                <select name="role" required>
                    <option value="manager" {{ form.role|default('manager') == 'manager' ? 'selected' : '' }}>{{ 'users.manager'|trans }}</option>
                    <option value="admin" {{ form.role|default('manager') == 'admin' ? 'selected' : '' }}>{{ 'users.admin'|trans }}</option>
                </select>
            </label>

            <label>
                {{ 'ui.status'|trans }}
                <select name="active">
                    <option value="1" {{ form.active|default(1) ? 'selected' : '' }}>{{ 'state.active'|trans }}</option>
                    <option value="0" {{ not form.active|default(1) ? 'selected' : '' }}>{{ 'state.inactive'|trans }}</option>
                </select>
            </label>

            {% if mode == 'new' %}
                <label>
                    {{ 'auth.password'|trans }}
                    <input type="password" name="password" minlength="8" required>
                </label>

                <label>
                    {{ 'users.confirm_password'|trans }}
                    <input type="password" name="password_confirm" minlength="8" required>
                </label>
            {% endif %}

            <button class="btn btn-primary" type="submit">{{ 'ui.save'|trans }}</button>
        </form>
    </section>
</main>
{% endblock %}
