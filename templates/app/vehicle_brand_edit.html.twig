{% extends 'base.html.twig' %}
{% block title %}{{ 'vehicles.brand'|trans }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>{{ brand.name }}</h1><a class="btn btn-dark" href="{{ path('app_vehicle_brand_show', {id: brand.id}) }}">{{ 'ui.back'|trans }}</a></section>
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message|trans }}</div>{% endfor %}
    <section class="panel">
        <form method="post" class="form-grid">
            <label>{{ 'vehicles.brand'|trans }}<input name="name" value="{{ brand.name }}" required></label>
            <button class="btn btn-primary" type="submit">{{ 'ui.update'|trans }}</button>
        </form>
    </section>
</main>
{% endblock %}
