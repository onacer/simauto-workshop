{% extends 'base.html.twig' %}

{% block title %}{{ 'billing.title'|trans }} - SIM Auto{% endblock %}

{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}

<main class="main-board">
    <section class="page-head">
        <h1>{{ 'billing.title'|trans }}</h1>
        <a class="btn btn-dark" href="{{ path('app_dashboard') }}">{{ 'ui.back'|trans }}</a>
    </section>

    <section class="panel">
        <div class="data-table">
            <div class="table-head"><span>{{ 'billing.invoice'|trans }}</span><span>{{ 'ui.client'|trans }}</span><span>{{ 'ui.amount'|trans }}</span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for operation in operations %}
                <div>
                    <strong>{{ operation.document_no|default(operation.invoice_no) }}</strong>
                    <span>{{ operation.client_real_name ?: operation.client_name }}</span>
                    <span>{{ operation.total|number_format(2, ',', ' ') }} DH</span>
                    <span class="row-actions">
                        <a href="{{ path('app_invoice', {id: operation.id}) }}">{{ 'billing.invoice'|trans }}</a>
                        <a href="{{ path('app_receipt', {id: operation.id}) }}">{{ 'billing.receipt'|trans }}</a>
                    </span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'billing.no_operations'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
