{% extends 'base.html.twig' %}
{% block title %}{{ product.name }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head">
        <h1>{{ product.name }}</h1>
        <span class="row-actions">
            {% if can('edit', user) %}<a href="{{ path('app_product_edit', {id: product.id}) }}">تعديل</a>{% endif %}
            <a class="btn btn-dark" href="{{ path('app_products') }}">رجوع</a>
        </span>
    </section>

    {% include 'app/_show_info.html.twig' with {rows: [
        {label: 'SKU', value: product.sku},
        {label: 'الصنف', value: product.category_name ?: product.category},
        {label: 'المخزون', value: product.stock_qty},
        {label: 'الحد الأدنى', value: product.min_qty},
        {label: 'ثمن الشراء', value: product.purchase_price ~ ' DH'},
        {label: 'ثمن البيع', value: product.sale_price ~ ' DH'},
        {label: 'الحالة', value: product.active ? 'نشط' : 'معطل'},
        {label: 'تاريخ الإنشاء', value: product.created_at}
    ]} %}

    <section class="panel">
        <h2>حركات المخزون</h2>
        <div class="data-table">
            <div class="table-head"><span>النوع</span><span>الكمية</span><span>المورد</span><span>التاريخ</span></div>
            {% for movement in movements %}
                <div>
                    <strong>{{ movement.movement_type }}</strong>
                    <span>{{ movement.quantity }}</span>
                    <span>{{ movement.supplier_name ?: '—' }}</span>
                    <span>{{ movement.created_at }}</span>
                </div>
            {% else %}
                <p class="empty-state">لا توجد حركات.</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
