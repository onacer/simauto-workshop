{% extends 'base.html.twig' %}

{% block title %}{{ 'products.title'|trans }} - SIM Auto{% endblock %}

{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}

<main class="main-board">
    <section class="page-head">
        <h1>{{ 'products.title'|trans }}</h1>
        <a class="btn btn-dark" href="{{ path('app_dashboard') }}">{{ 'ui.back'|trans }}</a>
    </section>

    {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message|trans }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message|trans }}</div>{% endfor %}

    <section class="panel">
        <form method="get" class="form-grid">
            <label>{{ 'ui.search'|trans }}<input name="q" value="{{ filters.q|default('') }}" placeholder="{{ 'products.search_placeholder'|trans }}" data-live-search data-live-target="#products-table"></label>
            <label>{{ 'products.category'|trans }}
                <select name="category_id" data-combobox data-combobox-min="10">
                    <option value="">{{ 'ui.all'|trans }}</option>
                    {% for category in categories %}
                        <option value="{{ category.id }}" {{ filters.category_id|default('') == category.id ? 'selected' : '' }}>{{ category.name }}</option>
                    {% endfor %}
                </select>
            </label>
            <label>{{ 'ui.active_record'|trans }}
                <select name="state">
                    <option value="active" {{ filters.state|default('active') == 'active' ? 'selected' : '' }}>{{ 'state.active'|trans }}</option>
                    <option value="inactive" {{ filters.state|default('active') == 'inactive' ? 'selected' : '' }}>{{ 'state.inactive'|trans }}</option>
                    <option value="all" {{ filters.state|default('active') == 'all' ? 'selected' : '' }}>{{ 'ui.all'|trans }}</option>
                </select>
            </label>
            <label>{{ 'products.stock_state'|trans }}
                <select name="stock_state">
                    <option value="">{{ 'ui.all'|trans }}</option>
                    <option value="low" {{ filters.stock_state|default('') == 'low' ? 'selected' : '' }}>{{ 'products.low'|trans }}</option>
                    <option value="empty" {{ filters.stock_state|default('') == 'empty' ? 'selected' : '' }}>{{ 'products.empty_stock'|trans }}</option>
                </select>
            </label>
            <button class="btn btn-dark" type="submit">{{ 'ui.filter'|trans }}</button>
        </form>
    </section>

    <section class="panel">
        <h2>{{ 'products.new'|trans }}</h2>
        <form action="{{ path('app_product_new') }}" method="post" class="form-grid product-pricing-form">
            <label>{{ 'ui.code'|trans }}<input name="sku" required></label>
            <label>{{ 'products.ref_universal'|trans }}<input name="ref_universal"></label>
            <label>{{ 'products.ref_company'|trans }}<input name="ref_company"></label>
            <label>{{ 'products.name'|trans }}<input name="name" required></label>
            <label>{{ 'products.type'|trans }}
                <select name="product_type" class="product-type">
                    <option value="stockable">{{ 'products.stockable'|trans }}</option>
                    <option value="service">{{ 'products.service'|trans }}</option>
                </select>
            </label>
            <label>{{ 'products.category'|trans }}
                <select name="category_id" required data-combobox data-combobox-min="10">
                    {% for category in categories %}
                        <option value="{{ category.id }}">{{ category.name }}</option>
                    {% endfor %}
                </select>
            </label>
            <label class="stock-field">{{ 'products.quantity'|trans }}<input name="stock_qty" type="number" step="1" min="0" value="0" required></label>
            <label>{{ 'products.min_qty'|trans }}<input name="min_qty" type="number" step="1" min="0" value="1"></label>
            <label>{{ 'products.purchase_price_ht'|trans }}<input name="purchase_price" class="purchase-price" type="number" step="0.01" min="0" value="0"></label>
            <label>{{ 'products.margin'|trans }}
                <select name="margin_mode" class="margin-mode">
                    <option value="manual">{{ 'products.manual'|trans }}</option>
                    <option value="135">35%</option>
                    <option value="145">45%</option>
                    <option value="155">55%</option>
                </select>
            </label>
            <label>{{ 'products.sale_price_ht'|trans }}<input name="sale_price" class="sale-price" type="number" step="0.01" min="0" value="0"></label>
            <button class="btn btn-primary" type="submit">{{ 'ui.save'|trans }}</button>
        </form>
    </section>

    <section class="panel">
        <div class="data-table products-table" id="products-table">
            <div class="table-head"><span>{{ 'products.product'|trans }}</span><span>{{ 'products.reference'|trans }}</span><span>{{ 'products.category'|trans }}</span><span>{{ 'products.stock'|trans }}</span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for product in products %}
                <div data-live-row data-search="{{ (product.sku ~ ' ' ~ product.ref_company|default('') ~ ' ' ~ product.ref_universal|default('') ~ ' ' ~ product.name ~ ' ' ~ (product.category_name ?: product.category))|lower }}">
                    <strong>{{ product.name }}<br><small>{{ product.sku }}</small></strong>
                    <span>
                        <strong>{{ product.ref_company ?: '—' }}</strong>
                        {% if product.ref_universal %}<br><small>{{ product.ref_universal }}</small>{% endif %}
                    </span>
                    <span>{{ product.category_name ?: product.category }}</span>
                    <span>{{ product.product_type|default('stockable') == 'service' ? 'products.service'|trans : product.stock_qty }}</span>
                    <span class="row-actions">
                        <a href="{{ path('app_product_show', {id: product.id}) }}">{{ 'ui.show'|trans }}</a>
                        {% if can('edit', user) %}<a href="{{ path('app_product_edit', {id: product.id}) }}">{{ 'ui.edit'|trans }}</a>{% endif %}
                        {% if can('toggle', user) %}
                            {% if product.active|default(1) == 1 %}
                                <form class="inline-form" method="post" action="{{ path('app_record_state', {entity: 'product', id: product.id, action: 'deactivate'}) }}">
                                    <input type="hidden" name="_token" value="{{ record_token }}">
                                    <button type="submit">{{ 'ui.deactivate'|trans }}</button>
                                </form>
                            {% else %}
                                <form class="inline-form" method="post" action="{{ path('app_record_state', {entity: 'product', id: product.id, action: 'reactivate'}) }}">
                                    <input type="hidden" name="_token" value="{{ record_token }}">
                                    <button type="submit">{{ 'ui.activate'|trans }}</button>
                                </form>
                            {% endif %}
                        {% endif %}
                        {% if can('delete', user) %}
                            <form class="inline-form" method="post" action="{{ path('app_record_state', {entity: 'product', id: product.id, action: 'delete'}) }}" onsubmit="return confirm('{{ 'ui.confirm_delete'|trans|e('js') }}')">
                                <input type="hidden" name="_token" value="{{ record_token }}">
                                <button type="submit">{{ 'ui.delete'|trans }}</button>
                            </form>
                        {% endif %}
                    </span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'products.no_products'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
