{% extends 'base.html.twig' %}
{% block title %}{{ 'vehicles.vehicle'|trans }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>{{ vehicle.plate }}</h1><a class="btn btn-dark" href="{{ path('app_vehicle_show', {id: vehicle.id}) }}">{{ 'ui.back'|trans }}</a></section>
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message|trans }}</div>{% endfor %}
    <section class="panel">
        <form method="post" class="form-grid">
            <label>{{ 'ui.client'|trans }}
                <select name="client_id" required data-combobox>
                    {% for client in clients %}
                        <option value="{{ client.id }}" {{ vehicle.client_id == client.id ? 'selected' : '' }}>{{ client.name }}</option>
                    {% endfor %}
                </select>
            </label>
            <label>{{ 'vehicles.plate'|trans }}<input name="plate" value="{{ vehicle.plate }}" required></label>
            <label>{{ 'vehicles.brand'|trans }}
                <select name="brand_id" required data-combobox data-brand-select>
                    {% for brand in brands %}
                        <option value="{{ brand.id }}" {{ vehicle.brand_id == brand.id ? 'selected' : '' }}>{{ brand.name }}</option>
                    {% endfor %}
                </select>
            </label>
            <label>{{ 'vehicles.model'|trans }}
                <select name="model_id" required data-combobox data-model-select>
                    {% for model in models %}
                        <option value="{{ model.id }}" data-brand-id="{{ model.brand_id }}" {{ vehicle.model_id == model.id ? 'selected' : '' }}>{{ model.brand_name }} - {{ model.name }}</option>
                    {% endfor %}
                </select>
            </label>
            <label>{{ 'vehicles.year'|trans }}<input name="year" type="number" min="1900" value="{{ vehicle.year }}"></label>
            <label>{{ 'vehicles.mileage'|trans }}<input name="mileage" type="number" min="0" value="{{ vehicle.mileage }}"></label>
            <label>{{ 'vehicles.notes'|trans }}<input name="notes" value="{{ vehicle.notes }}"></label>
            <button class="btn btn-primary" type="submit">{{ 'ui.update'|trans }}</button>
        </form>
    </section>
</main>
{% endblock %}
