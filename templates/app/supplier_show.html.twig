{% extends 'base.html.twig' %}
{% block title %}{{ supplier.name }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head">
        <h1>{{ supplier.name }}</h1>
        <span class="row-actions">
            {% include 'app/_action_button.html.twig' with {
                label: 'ui.edit'|trans,
                url: path('app_supplier_edit', {id: supplier.id}),
                active: can('edit.reference', user),
                class: 'btn btn-primary',
                reason: 'access.admin_only'|trans
            } only %}
            <a class="btn btn-dark" href="{{ path('app_suppliers') }}">{{ 'ui.back'|trans }}</a>
        </span>
    </section>

    {% include 'app/_show_info.html.twig' with {rows: [
        {label: 'ui.phone'|trans, value: supplier.phone},
        {label: 'ui.email'|trans, value: supplier.email},
        {label: 'ICE', value: supplier.ice},
        {label: 'ui.address'|trans, value: supplier.address},
        {label: 'ui.status'|trans, value: supplier.active ? 'state.active'|trans : 'ui.disabled'|trans},
        {label: 'ui.created_at'|trans, value: supplier.created_at}
    ]} %}

    <section class="panel">
        <h2>{{ 'suppliers.last_stock_entries'|trans }}</h2>
        <div class="data-table">
            <div class="table-head"><span>{{ 'ui.date'|trans }}</span><span>{{ 'products.product'|trans }}</span><span>{{ 'stock.quantity'|trans }}</span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for movement in movements %}
                <div>
                    <strong>{{ movement.created_at }}</strong>
                    <span>{{ movement.product_name }}<br><small>{{ movement.sku }}</small></span>
                    <span>{{ movement.quantity }}</span>
                    <span class="row-actions">
                        {% include 'app/_action_button.html.twig' with {
                            label: 'ui.edit'|trans,
                            active: false,
                            reason: 'access.stock_locked'|trans
                        } only %}
                        {% include 'app/_action_button.html.twig' with {
                            label: 'ui.delete'|trans,
                            active: false,
                            reason: 'access.stock_locked'|trans
                        } only %}
                    </span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'suppliers.no_related_entries'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
