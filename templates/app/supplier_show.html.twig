{% extends 'base.html.twig' %}
{% block title %}{{ supplier.name }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head">
        <h1>{{ supplier.name }}</h1>
        <span class="row-actions">
            {% if can('edit', user) %}<a href="{{ path('app_supplier_edit', {id: supplier.id}) }}">تعديل</a>{% endif %}
            <a class="btn btn-dark" href="{{ path('app_suppliers') }}">رجوع</a>
        </span>
    </section>

    {% include 'app/_show_info.html.twig' with {rows: [
        {label: 'الهاتف', value: supplier.phone},
        {label: 'البريد', value: supplier.email},
        {label: 'ICE', value: supplier.ice},
        {label: 'العنوان', value: supplier.address},
        {label: 'الحالة', value: supplier.active ? 'نشط' : 'معطل'},
        {label: 'تاريخ الإنشاء', value: supplier.created_at}
    ]} %}

    <section class="panel">
        <h2>آخر إدخالات المخزون</h2>
        <div class="data-table">
            <div class="table-head"><span>التاريخ</span><span>المنتج</span><span>الكمية</span><span>ثمن الشراء</span></div>
            {% for movement in movements %}
                <div>
                    <strong>{{ movement.created_at }}</strong>
                    <span>{{ movement.product_name }}<br><small>{{ movement.sku }}</small></span>
                    <span>{{ movement.quantity }}</span>
                    <span>{{ movement.unit_cost is not empty ? movement.unit_cost ~ ' DH' : '—' }}</span>
                </div>
            {% else %}
                <p class="empty-state">لا توجد إدخالات مخزون مرتبطة بهذا المورد.</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
