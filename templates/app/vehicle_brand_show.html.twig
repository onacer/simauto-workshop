{% extends 'base.html.twig' %}
{% block title %}{{ brand.name }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head">
        <h1>{{ brand.name }}</h1>
        <span class="row-actions">
            {% include 'app/_action_button.html.twig' with {
                label: 'ui.edit'|trans,
                url: path('app_vehicle_brand_edit', {id: brand.id}),
                active: can('edit.reference', user),
                class: 'btn btn-primary',
                reason: 'access.admin_only'|trans
            } only %}
            <a class="btn btn-dark" href="{{ path('app_vehicle_settings') }}">{{ 'ui.back'|trans }}</a>
        </span>
    </section>

    {% include 'app/_show_info.html.twig' with {rows: [
        {label: 'vehicles.brand'|trans, value: brand.name}
    ]} %}

    <section class="panel">
        <h2>{{ 'vehicles.models'|trans }}</h2>
        <div class="data-table">
            <div class="table-head"><span>{{ 'vehicles.model'|trans }}</span><span></span><span></span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for model in models %}
                <div>
                    <strong>{{ model.name }}</strong>
                    <span></span><span></span>
                    <span class="row-actions">
                        <a href="{{ path('app_vehicle_model_show', {id: model.id}) }}">{{ 'ui.show'|trans }}</a>
                        {% include 'app/_action_button.html.twig' with {
                            label: 'ui.edit'|trans,
                            url: path('app_vehicle_model_edit', {id: model.id}),
                            active: can('edit.reference', user),
                            reason: 'access.admin_only'|trans
                        } only %}
                    </span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'vehicles.no_brand_models'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
