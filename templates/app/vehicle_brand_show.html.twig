{% extends 'base.html.twig' %}
{% block title %}{{ brand.name }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head">
        <h1>{{ brand.name }}</h1>
        <a class="btn btn-dark" href="{{ path('app_vehicle_settings') }}">رجوع</a>
    </section>

    {% include 'app/_show_info.html.twig' with {rows: [
        {label: 'الماركة', value: brand.name}
    ]} %}

    <section class="panel">
        <h2>الموديلات</h2>
        <div class="data-table">
            <div class="table-head"><span>الموديل</span><span></span><span></span><span>إجراءات</span></div>
            {% for model in models %}
                <div>
                    <strong>{{ model.name }}</strong>
                    <span></span><span></span>
                    <span class="row-actions"><a href="{{ path('app_vehicle_model_show', {id: model.id}) }}">عرض</a></span>
                </div>
            {% else %}
                <p class="empty-state">لا توجد موديلات مرتبطة بهذه الماركة.</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
