{% extends 'base.html.twig' %}
{% block title %}{{ category.name }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head">
        <h1>{{ category.name }}</h1>
        <span class="row-actions">
            {% if can('edit.reference', user) %}<a href="{{ path('app_category_edit', {id: category.id}) }}">{{ 'ui.edit'|trans }}</a>{% endif %}
            <a class="btn btn-dark" href="{{ path('app_categories') }}">{{ 'ui.back'|trans }}</a>
        </span>
    </section>

    {% include 'app/_show_info.html.twig' with {rows: [
        {label: 'ui.status'|trans, value: category.active ? 'state.active'|trans : 'ui.disabled'|trans},
        {label: 'ui.created_at'|trans, value: category.created_at}
    ]} %}

    <section class="panel">
        <h2>{{ 'products.category_products'|trans }}</h2>
        <div class="data-table">
            <div class="table-head"><span>{{ 'products.product'|trans }}</span><span>SKU</span><span>{{ 'products.stock'|trans }}</span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for product in products %}
                <div>
                    <strong>{{ product.name }}</strong>
                    <span>{{ product.sku }}</span>
                    <span>{{ product.stock_qty }}</span>
                    <span class="row-actions"><a href="{{ path('app_product_show', {id: product.id}) }}">{{ 'ui.show'|trans }}</a></span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'products.no_category_products'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
