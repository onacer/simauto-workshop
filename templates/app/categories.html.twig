{% extends 'base.html.twig' %}
{% block title %}الأصناف - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>الأصناف</h1><a class="btn btn-dark" href="{{ path('app_dashboard') }}">رجوع</a></section>
    {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message }}</div>{% endfor %}
    <section class="panel">
        <form method="post" class="form-grid">
            <label>اسم الصنف<input name="name" required></label>
            <button class="btn btn-primary" type="submit">حفظ</button>
        </form>
    </section>
    <section class="panel">
        <div class="data-table">
            <div class="table-head"><span>الصنف</span><span>الحالة</span><span>تاريخ الإنشاء</span><span>إجراءات</span></div>
            {% for category in categories %}
                <div>
                    <strong>{{ category.name }}</strong>
                    <span>{{ category.active ? 'نشط' : 'معطل' }}</span>
                    <span>{{ category.created_at }}</span>
                    <span class="row-actions">
                        <a href="{{ path('app_category_show', {id: category.id}) }}">عرض</a>
                        {% if can('edit', user) %}<a href="{{ path('app_category_edit', {id: category.id}) }}">تعديل</a>{% endif %}
                        {% if can('delete', user) %}
                            <form method="post" action="{{ path('app_category_deactivate', {id: category.id}) }}"><button class="link-button">تعطيل</button></form>
                        {% endif %}
                    </span>
                </div>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
