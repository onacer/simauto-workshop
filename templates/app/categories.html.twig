{% extends 'base.html.twig' %}
{% block title %}{{ 'categories.title'|trans }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>{{ 'categories.title'|trans }}</h1><a class="btn btn-dark" href="{{ path('app_dashboard') }}">{{ 'ui.back'|trans }}</a></section>
    {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message|trans }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message|trans }}</div>{% endfor %}
    {% if can('edit', user) %}
        <section class="panel">
            <form method="post" class="form-grid">
                <label>{{ 'categories.name'|trans }}<input name="name" required></label>
                <button class="btn btn-primary" type="submit">{{ 'ui.save'|trans }}</button>
            </form>
        </section>
    {% endif %}
    <section class="panel">
        <div class="data-table">
            <div class="table-head"><span>{{ 'categories.category'|trans }}</span><span>{{ 'ui.status'|trans }}</span><span>{{ 'ui.created_at'|trans }}</span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for category in categories %}
                <div>
                    <strong>{{ category.name }}</strong>
                    <span>{{ category.active ? 'state.active'|trans : 'ui.disabled'|trans }}</span>
                    <span>{{ category.created_at }}</span>
                    <span class="row-actions">
                        <a href="{{ path('app_category_show', {id: category.id}) }}">{{ 'ui.show'|trans }}</a>
                        {% if can('edit', user) %}<a href="{{ path('app_category_edit', {id: category.id}) }}">{{ 'ui.edit'|trans }}</a>{% endif %}
                        {% if can('toggle', user) %}
                            <form method="post" action="{{ path('app_category_deactivate', {id: category.id}) }}"><button class="link-button">{{ 'ui.deactivate'|trans }}</button></form>
                        {% endif %}
                    </span>
                </div>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
