{% extends 'base.html.twig' %}

{% block title %}{{ 'operations.title'|trans }} - SIM Auto{% endblock %}

{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
{% set is_edit = operation is defined %}
{% set form_lines = is_edit and operation.items is not empty ? operation.items : [{}] %}

<main class="main-board">
    <section class="page-head">
        <h1>{{ is_edit ? 'operations.edit_quote'|trans : 'operations.quote_title'|trans }}</h1>
        <span class="row-actions">
            <a class="btn btn-primary" href="{{ path('app_operations_history') }}">{{ 'operations.history.title'|trans }}</a>
            <a class="btn btn-dark" href="{{ path('app_dashboard') }}">{{ 'ui.back'|trans }}</a>
        </span>
    </section>

    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message|trans }}</div>{% endfor %}

    <section class="panel">
        <form action="{{ is_edit ? path('app_operation_edit', {id: operation.id}) : path('app_operation_new') }}" method="post" class="operation-form dynamic-operation-form">
            <input type="hidden" name="_token" value="{{ operation_token }}">
            <div class="form-grid">
                <label>{{ 'ui.client'|trans }}
                    <select name="client_id" required data-combobox>
                        <option value="">{{ 'operations.choose_client'|trans }}</option>
                        {% for client in clients %}
                            <option value="{{ client.id }}" {{ is_edit and operation.client_id == client.id ? 'selected' : '' }} data-search="{{ (client.name ~ ' ' ~ client.phone ~ ' ' ~ client.email)|lower }}">{{ client.name }}{% if client.phone %} - {{ client.phone }}{% endif %}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>{{ 'operations.vehicle'|trans }}
                    <select name="vehicle_id" required data-combobox data-vehicle-select>
                        <option value="">{{ 'operations.choose_vehicle'|trans }}</option>
                        {% for vehicle in vehicles %}
                            <option value="{{ vehicle.id }}" {{ is_edit and operation.vehicle_id == vehicle.id ? 'selected' : '' }} data-client-id="{{ vehicle.client_id }}" data-search="{{ (vehicle.plate ~ ' ' ~ vehicle.brand_name ~ ' ' ~ vehicle.model_name ~ ' ' ~ vehicle.client_name)|lower }}">{{ vehicle.client_name }} - {{ vehicle.plate }} - {{ vehicle.brand_name }} {{ vehicle.model_name }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>{{ 'operations.payment'|trans }}
                    <select name="payment_method" class="payment-method">
                        <option value="ESP" {{ is_edit and operation.payment_method == 'ESP' ? 'selected' : '' }}>{{ 'payment.cash'|trans }}</option>
                        <option value="CHQ" {{ is_edit and operation.payment_method == 'CHQ' ? 'selected' : '' }}>{{ 'payment.cheque'|trans }}</option>
                        <option value="CB" {{ is_edit and operation.payment_method == 'CB' ? 'selected' : '' }}>{{ 'payment.card'|trans }}</option>
                        <option value="VIR" {{ is_edit and operation.payment_method == 'VIR' ? 'selected' : '' }}>{{ 'payment.transfer'|trans }}</option>
                    </select>
                </label>
                <label class="check-field is-hidden">{{ 'operations.check_number'|trans }}<input name="check_number" value="{{ is_edit ? operation.check_number : '' }}"></label>
                <input name="vat_rate" class="operation-vat-rate" type="hidden" value="{{ is_edit ? operation.vat_rate : 20 }}">
            </div>

            <div class="operation-lines" data-operation-lines>
                <div class="operation-line operation-line-head">
                    <span>{{ 'operations.product_service'|trans }}</span>
                    <span>{{ 'operations.label'|trans }}</span>
                    <span>{{ 'operations.quantity'|trans }}</span>
                    <span>{{ 'operations.margin'|trans }}</span>
                    <span>{{ 'operations.price_ttc'|trans }}</span>
                    <span>{{ 'operations.discount'|trans }}</span>
                    <span>{{ 'operations.line_total_ttc'|trans }}</span>
                </div>
                {% for line in form_lines %}
                <div class="operation-line" data-line>
                    <select name="line_product_id[]" class="line-product" data-combobox>
                        <option value="" {{ line.product_id|default('') ? '' : 'selected' }} data-price="0" data-name="" data-purchase-price="0" data-margin-rate="" data-product-type="service">{{ 'operations.free_line'|trans }}</option>
                        {% for product in products %}
                            {% set product_ref = product.ref_company ?: (product.ref_universal ?: product.sku) %}
                            <option value="{{ product.id }}"
                                    {{ line.product_id|default(0) == product.id ? 'selected' : '' }}
                                    data-price="{{ product.sale_price }}"
                                    data-purchase-price="{{ product.purchase_price }}"
                                    data-margin-rate="{{ product.margin_rate }}"
                                    data-product-type="{{ product.product_type|default('stockable') }}"
                                    data-name="{{ product.name }}"
                                    data-ref-company="{{ product.ref_company }}"
                                    data-ref-universal="{{ product.ref_universal }}"
                                    data-sku="{{ product.sku }}"
                                    data-search="{{ (product.ref_company ~ ' ' ~ product.ref_universal ~ ' ' ~ product.sku ~ ' ' ~ product.name)|lower }}">
                                [{{ product_ref }}] {{ product.name }} - {{ product.stock_qty }} - {{ product.sale_price }} DH
                            </option>
                        {% endfor %}
                    </select>
                    <input name="line_label[]" class="line-label" placeholder="{{ 'operations.label'|trans }}" value="{{ line.label|default('') }}">
                    <input name="line_quantity[]" class="line-qty" type="number" step="0.01" min="0" value="{{ line.quantity|default(1) }}">
                    <select name="line_margin_mode[]" class="line-margin-mode">
                        <option value="manual">{{ 'products.manual'|trans }}</option>
                        <option value="135">35%</option>
                        <option value="145">45%</option>
                        <option value="155">55%</option>
                    </select>
                    <input name="line_unit_price[]" class="line-price" type="number" step="0.01" min="0" value="{{ line.unit_price|default(0) }}">
                    <input name="line_discount[]" class="line-discount" type="number" step="0.01" min="0" max="100" value="{{ line.discount_rate|default(0) }}">
                    <strong class="line-total">0.00 DH</strong>
                </div>
                {% endfor %}
            </div>

            <button class="btn btn-dark" type="button" data-add-line>+ {{ 'operations.add_line'|trans }}</button>

            <div class="operation-preview">
                <span>{{ 'operations.total_ttc'|trans }}: <strong data-total-ttc>0.00 DH</strong></span>
            </div>

            <button class="btn btn-primary" type="submit">{{ is_edit ? 'ui.update'|trans : 'operations.save_quote'|trans }}</button>
        </form>
    </section>
</main>
{% endblock %}
