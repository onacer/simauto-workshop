{% extends 'base.html.twig' %}

{% block title %}العمليات - SIM Auto{% endblock %}

{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}

<main class="main-board">
    <section class="page-head">
        <h1>عملية جديدة</h1>
        <a class="btn btn-dark" href="{{ path('app_dashboard') }}">رجوع</a>
    </section>

    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message }}</div>{% endfor %}

    <section class="panel">
        <form action="{{ path('app_operation_new') }}" method="post" class="operation-form">
            <div class="form-grid">
                <label>العميل
                    <select name="client_id" required>
                        <option value="">اختر العميل</option>
                        {% for client in clients %}
                            <option value="{{ client.id }}">{{ client.name }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>السيارة
                    <select name="vehicle_id" required>
                        <option value="">اختر السيارة</option>
                        {% for vehicle in vehicles %}
                            <option value="{{ vehicle.id }}">{{ vehicle.client_name }} - {{ vehicle.plate }} - {{ vehicle.brand_name }} {{ vehicle.model_name }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>الدفع
                    <select name="payment_method">
                        <option value="ESP">ESP</option>
                        <option value="CARTE">CARTE</option>
                        <option value="VIREMENT">VIREMENT</option>
                    </select>
                </label>
            </div>

            <div class="lines-grid">
                {% for i in 1..3 %}
                    <label>قطعة {{ i }}
                        <select name="product_{{ i }}">
                            <option value="0">بدون</option>
                            {% for product in products %}
                                <option value="{{ product.id }}">{{ product.name }} - stock {{ product.stock_qty }} - {{ product.sale_price }} DH</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label>الكمية<input name="product_qty_{{ i }}" type="number" step="1" min="0" value="0"></label>
                {% endfor %}
                <label>خدمة 1<input name="service_label_1"></label>
                <label>الثمن<input name="service_price_1" type="number" step="0.01" min="0" value="0"></label>
                <label>خدمة 2<input name="service_label_2"></label>
                <label>الثمن<input name="service_price_2" type="number" step="0.01" min="0" value="0"></label>
            </div>

            <button class="btn btn-primary" type="submit">حفظ وطباعة الفاتورة</button>
        </form>
    </section>
</main>
{% endblock %}
