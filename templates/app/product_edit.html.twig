{% extends 'base.html.twig' %}
{% block title %}{{ 'products.edit'|trans }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>{{ 'products.edit'|trans }}</h1><a class="btn btn-dark" href="{{ path('app_product_show', {id: product.id}) }}">{{ 'ui.back'|trans }}</a></section>
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message|trans }}</div>{% endfor %}
    <section class="panel">
        <form method="post" class="form-grid product-pricing-form">
            <label>{{ 'ui.code'|trans }}<input name="sku" value="{{ product.sku }}" required></label>
            <label>{{ 'products.ref_universal'|trans }}<input name="ref_universal" value="{{ product.ref_universal }}"></label>
            <label>{{ 'products.ref_company'|trans }}<input name="ref_company" value="{{ product.ref_company }}"></label>
            <label>{{ 'products.name'|trans }}<input name="name" value="{{ product.name }}" required></label>
            <label>{{ 'products.type'|trans }}
                <select name="product_type" class="product-type">
                    <option value="stockable" {{ product.product_type|default('stockable') == 'stockable' ? 'selected' : '' }}>{{ 'products.stockable'|trans }}</option>
                    <option value="service" {{ product.product_type|default('stockable') == 'service' ? 'selected' : '' }}>{{ 'products.service'|trans }}</option>
                </select>
            </label>
            <label>{{ 'products.category'|trans }}<select name="category_id" required data-combobox data-combobox-min="10">{% for category in categories %}<option value="{{ category.id }}" {{ product.category_id == category.id ? 'selected' : '' }}>{{ category.name }}</option>{% endfor %}</select></label>
            <label>{{ 'products.min_qty'|trans }}<input name="min_qty" type="number" min="0" value="{{ product.min_qty }}"></label>
            <label>{{ 'products.purchase_price'|trans }}<input name="purchase_price" class="purchase-price" type="number" step="0.01" min="0" value="{{ product.purchase_price }}"></label>
            <label>{{ 'products.margin'|trans }}
                <select name="margin_mode" class="margin-mode">
                    <option value="manual" {{ product.margin_rate is empty ? 'selected' : '' }}>{{ 'products.manual'|trans }}</option>
                    <option value="135" {{ product.margin_rate == 135 ? 'selected' : '' }}>35%</option>
                    <option value="145" {{ product.margin_rate == 145 ? 'selected' : '' }}>45%</option>
                    <option value="155" {{ product.margin_rate == 155 ? 'selected' : '' }}>55%</option>
                </select>
            </label>
            <label>{{ 'products.sale_price'|trans }}<input name="sale_price" class="sale-price" type="number" step="0.01" min="0" value="{{ product.sale_price }}"></label>
            <button class="btn btn-primary" type="submit">{{ 'ui.update'|trans }}</button>
        </form>
    </section>
    <section class="panel">
        {% if can('toggle', user) %}
            <form method="post" action="{{ path('app_product_deactivate', {id: product.id}) }}">
                <button class="btn btn-dark" type="submit">{{ 'ui.deactivate'|trans }}</button>
            </form>
        {% endif %}
    </section>
</main>
{% endblock %}
