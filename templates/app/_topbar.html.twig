{% set route = app.request.attributes.get('_route') %}
{% set locale = app.request.locale|default('ar') %}

<header class="topbar" data-topbar>
    <a class="topbar-logo" href="{{ path('app_dashboard') }}" aria-label="SIM Auto">
        <img src="{{ asset('images/logo-light.png') }}" alt="SIM Auto">
    </a>

    <button class="mobile-menu-toggle" type="button" aria-label="{{ 'nav.menu'|trans }}" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <nav class="topbar-nav" aria-label="{{ 'nav.main_menu'|trans }}">
        <a class="topbar-item {{ route == 'app_dashboard' ? 'is-active' : '' }}" href="{{ path('app_dashboard') }}">{{ 'nav.dashboard'|trans }}</a>

        <div class="nav-dropdown {{ route in ['app_products', 'app_product_show', 'app_product_edit', 'app_stock', 'app_categories', 'app_category_show', 'app_category_edit', 'app_suppliers', 'app_supplier_show', 'app_supplier_edit'] ? 'is-current' : '' }}">
            <a class="topbar-item dropdown-toggle" href="{{ path('app_products') }}" aria-expanded="false">{{ 'nav.stock'|trans }}</a>
            <div class="dropdown-menu">
                <a href="{{ path('app_products') }}">{{ 'nav.products'|trans }}</a>
                <a href="{{ path('app_stock') }}">{{ 'nav.stock_in'|trans }}</a>
                <a href="{{ path('app_categories') }}">{{ 'nav.categories'|trans }}</a>
                <a href="{{ path('app_suppliers') }}">{{ 'nav.suppliers'|trans }}</a>
            </div>
        </div>

        <div class="nav-dropdown {{ route in ['app_vehicles', 'app_vehicle_show', 'app_vehicle_settings', 'app_vehicle_brand_show', 'app_vehicle_model_show'] ? 'is-current' : '' }}">
            <a class="topbar-item dropdown-toggle" href="{{ path('app_vehicles') }}" aria-expanded="false">{{ 'nav.vehicles'|trans }}</a>
            <div class="dropdown-menu">
                <a href="{{ path('app_vehicles') }}">{{ 'nav.vehicles'|trans }}</a>
                <a href="{{ path('app_vehicle_settings') }}">{{ 'nav.vehicle_settings'|trans }}</a>
            </div>
        </div>

        <a class="topbar-item {{ route in ['app_clients', 'app_client_show', 'app_client_edit'] ? 'is-active' : '' }}" href="{{ path('app_clients') }}">{{ 'nav.clients'|trans }}</a>

        <div class="nav-dropdown {{ route in ['app_operations', 'app_operations_history', 'app_operation_show', 'app_billing', 'app_document', 'app_invoice', 'app_receipt'] ? 'is-current' : '' }}">
            <a class="topbar-item dropdown-toggle" href="{{ path('app_operations') }}" aria-expanded="false">{{ 'nav.operations'|trans }}</a>
            <div class="dropdown-menu">
                <a href="{{ path('app_operations') }}">{{ 'nav.new_operation'|trans }}</a>
                <a href="{{ path('app_operations_history') }}">{{ 'nav.operations_history'|trans }}</a>
                <a href="{{ path('app_billing') }}">{{ 'nav.billing'|trans }}</a>
            </div>
        </div>

        {% if can('imports', user) or can('manage_users', user) or can('reports.view', user) %}
            <div class="nav-dropdown {{ route starts with 'app_import' or route starts with 'app_user' or route == 'app_users' or route starts with 'app_report' ? 'is-current' : '' }}">
                <a class="topbar-item dropdown-toggle" href="{{ can('reports.view', user) ? path('app_report_finance') : path('app_import') }}" aria-expanded="false">{{ 'nav.admin'|trans }}</a>
                <div class="dropdown-menu">
                    {% if can('reports.view', user) %}
                        <a href="{{ path('app_report_finance') }}">{{ 'nav.reports'|trans }}</a>
                    {% endif %}
                    {% if can('imports', user) %}
                        <a href="{{ path('app_import') }}">{{ 'nav.imports'|trans }}</a>
                    {% endif %}
                    {% if can('manage_users', user) %}
                        <a href="{{ path('app_users') }}">{{ 'nav.users'|trans }}</a>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </nav>

    <div class="topbar-user">
        <span class="locale-switch topbar-locale" aria-label="Language">
            <a href="{{ path('app_locale', {locale: 'ar'}) }}" class="{{ locale == 'ar' ? 'is-active' : '' }}">AR</a>
            <b>|</b>
            <a href="{{ path('app_locale', {locale: 'fr'}) }}" class="{{ locale == 'fr' ? 'is-active' : '' }}">FR</a>
        </span>
        <div class="nav-dropdown profile-dropdown {{ route == 'app_profile_password' ? 'is-current' : '' }}">
            <a class="topbar-item dropdown-toggle profile-toggle" href="{{ path('app_profile_password') }}" aria-expanded="false">
                <span class="topbar-username">{{ user.name }}</span>
            </a>
            <div class="dropdown-menu profile-menu">
                <a href="{{ path('app_profile_password') }}">{{ 'nav.password'|trans }}</a>
                <a href="{{ path('app_logout') }}">{{ 'nav.logout'|trans }}</a>
            </div>
        </div>
    </div>
</header>
