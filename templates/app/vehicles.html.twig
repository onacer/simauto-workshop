{% extends 'base.html.twig' %}
{% block title %}{{ 'vehicles.title'|trans }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head">
        <h1>{{ 'vehicles.title'|trans }}</h1>
        <span class="row-actions">
            {% if user.role == 'admin' %}<a href="{{ path('app_vehicle_settings') }}">{{ 'vehicles.settings'|trans }}</a>{% endif %}
            <a class="btn btn-dark" href="{{ path('app_dashboard') }}">{{ 'ui.back'|trans }}</a>
        </span>
    </section>
    {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message|trans }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message|trans }}</div>{% endfor %}
    <section class="panel">
        <form method="post" class="form-grid">
            <label>{{ 'ui.client'|trans }}
                <select name="client_id" required>
                    {% for client in clients %}
                        <option value="{{ client.id }}" {{ selected_client_id|default(0) == client.id ? 'selected' : '' }}>{{ client.name }}</option>
                    {% endfor %}
                </select>
            </label>
            <label>{{ 'vehicles.plate'|trans }}<input name="plate" required></label>
            <label>{{ 'vehicles.brand'|trans }}<select name="brand_id" required>{% for brand in brands %}<option value="{{ brand.id }}">{{ brand.name }}</option>{% endfor %}</select></label>
            <label>{{ 'vehicles.model'|trans }}<select name="model_id" required>{% for model in models %}<option value="{{ model.id }}">{{ model.brand_name }} - {{ model.name }}</option>{% endfor %}</select></label>
            <label>{{ 'vehicles.year'|trans }}<input name="year" type="number" min="1900"></label>
            <label>{{ 'vehicles.mileage'|trans }}<input name="mileage" type="number" min="0"></label>
            <label>{{ 'vehicles.notes'|trans }}<input name="notes"></label>
            <button class="btn btn-primary" type="submit">{{ 'ui.save'|trans }}</button>
        </form>
    </section>
    <section class="panel">
        <div class="data-table">
            <div class="table-head"><span>{{ 'vehicles.vehicle'|trans }}</span><span>{{ 'ui.client'|trans }}</span><span>{{ 'vehicles.brand'|trans }}</span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for vehicle in vehicles %}
                <div>
                    <strong>{{ vehicle.plate }}</strong>
                    <span>{{ vehicle.client_name }}</span>
                    <span>{{ vehicle.brand_name }} {{ vehicle.model_name }}</span>
                    <span class="row-actions"><a href="{{ path('app_vehicle_show', {id: vehicle.id}) }}">{{ 'ui.show'|trans }}</a></span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'vehicles.no_vehicles'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
