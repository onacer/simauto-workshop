{% extends 'base.html.twig' %}
{% block title %}إعدادات السيارات - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>الماركات والموديلات</h1><a class="btn btn-dark" href="{{ path('app_vehicles') }}">رجوع</a></section>
    {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message }}</div>{% endfor %}
    <section class="work-grid">
        <article class="panel">
            <h2>ماركة جديدة</h2>
            <form method="post" class="form-stack">
                <input type="hidden" name="kind" value="brand">
                <label>الاسم<input name="name" required></label>
                <button class="btn btn-primary">حفظ</button>
            </form>
        </article>
        <article class="panel">
            <h2>موديل جديد</h2>
            <form method="post" class="form-stack">
                <input type="hidden" name="kind" value="model">
                <label>الماركة<select name="brand_id">{% for brand in brands %}<option value="{{ brand.id }}">{{ brand.name }}</option>{% endfor %}</select></label>
                <label>الموديل<input name="name" required></label>
                <button class="btn btn-primary">حفظ</button>
            </form>
        </article>
    </section>
    <section class="panel">
        <h2>الماركات</h2>
        <div class="data-table">
            <div class="table-head"><span>الماركة</span><span></span><span></span><span>إجراءات</span></div>
            {% for brand in brands %}
                <div>
                    <strong>{{ brand.name }}</strong>
                    <span></span><span></span>
                    <span class="row-actions"><a href="{{ path('app_vehicle_brand_show', {id: brand.id}) }}">عرض</a></span>
                </div>
            {% else %}
                <p class="empty-state">لا توجد ماركات.</p>
            {% endfor %}
        </div>
    </section>
    <section class="panel">
        <h2>الموديلات</h2>
        <div class="data-table">
            <div class="table-head"><span>الماركة</span><span>الموديل</span><span></span><span>إجراءات</span></div>
            {% for model in models %}
                <div>
                    <strong><a href="{{ path('app_vehicle_brand_show', {id: model.brand_id}) }}">{{ model.brand_name }}</a></strong>
                    <span>{{ model.name }}</span>
                    <span></span>
                    <span class="row-actions"><a href="{{ path('app_vehicle_model_show', {id: model.id}) }}">عرض</a></span>
                </div>
            {% else %}
                <p class="empty-state">لا توجد موديلات.</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
