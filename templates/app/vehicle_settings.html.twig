{% extends 'base.html.twig' %}
{% block title %}إعدادات السيارات - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>الماركات والموديلات</h1><a class="btn btn-dark" href="{{ path('app_vehicles') }}">رجوع</a></section>
    {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message }}</div>{% endfor %}
    <section class="work-grid">
        <article class="panel">
            <h2>ماركة جديدة</h2>
            <form method="post" class="form-stack">
                <input type="hidden" name="kind" value="brand">
                <label>الاسم<input name="name" required></label>
                <button class="btn btn-primary">حفظ</button>
            </form>
        </article>
        <article class="panel">
            <h2>موديل جديد</h2>
            <form method="post" class="form-stack">
                <input type="hidden" name="kind" value="model">
                <label>الماركة<select name="brand_id">{% for brand in brands %}<option value="{{ brand.id }}">{{ brand.name }}</option>{% endfor %}</select></label>
                <label>الموديل<input name="name" required></label>
                <button class="btn btn-primary">حفظ</button>
            </form>
        </article>
    </section>
    <section class="panel">
        <div class="data-table">
            <div class="table-head"><span>الماركة</span><span>الموديل</span><span></span><span></span></div>
            {% for model in models %}
                <div><strong>{{ model.brand_name }}</strong><span>{{ model.name }}</span><span></span><span></span></div>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
