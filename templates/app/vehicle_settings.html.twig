{% extends 'base.html.twig' %}
{% block title %}{{ 'vehicles.settings'|trans }} - SIM Auto{% endblock %}
{% block body %}
{% include 'app/_topbar.html.twig' with {user: user} %}
<main class="main-board">
    <section class="page-head"><h1>{{ 'vehicles.settings'|trans }}</h1><a class="btn btn-dark" href="{{ path('app_vehicles') }}">{{ 'ui.back'|trans }}</a></section>
    {% for message in app.flashes('success') %}<div class="alert alert-success">{{ message|trans }}</div>{% endfor %}
    {% for message in app.flashes('error') %}<div class="alert alert-error">{{ message|trans }}</div>{% endfor %}
    <section class="work-grid">
        <article class="panel">
            <h2>{{ 'vehicles.new_brand'|trans }}</h2>
            <form method="post" class="form-stack">
                <input type="hidden" name="kind" value="brand">
                <label>{{ 'ui.name'|trans }}<input name="name" required></label>
                <button class="btn btn-primary">{{ 'ui.save'|trans }}</button>
            </form>
        </article>
        <article class="panel">
            <h2>{{ 'vehicles.new_model'|trans }}</h2>
            <form method="post" class="form-stack">
                <input type="hidden" name="kind" value="model">
                <label>{{ 'vehicles.brand'|trans }}<select name="brand_id">{% for brand in brands %}<option value="{{ brand.id }}">{{ brand.name }}</option>{% endfor %}</select></label>
                <label>{{ 'vehicles.model'|trans }}<input name="name" required></label>
                <button class="btn btn-primary">{{ 'ui.save'|trans }}</button>
            </form>
        </article>
    </section>
    <section class="panel">
        <h2>{{ 'vehicles.brands'|trans }}</h2>
        <div class="data-table">
            <div class="table-head"><span>{{ 'vehicles.brand'|trans }}</span><span></span><span></span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for brand in brands %}
                <div>
                    <strong>{{ brand.name }}</strong>
                    <span></span><span></span>
                    <span class="row-actions"><a href="{{ path('app_vehicle_brand_show', {id: brand.id}) }}">{{ 'ui.show'|trans }}</a></span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'vehicles.no_brands'|trans }}</p>
            {% endfor %}
        </div>
    </section>
    <section class="panel">
        <h2>{{ 'vehicles.models'|trans }}</h2>
        <div class="data-table">
            <div class="table-head"><span>{{ 'vehicles.brand'|trans }}</span><span>{{ 'vehicles.model'|trans }}</span><span></span><span>{{ 'ui.actions'|trans }}</span></div>
            {% for model in models %}
                <div>
                    <strong><a href="{{ path('app_vehicle_brand_show', {id: model.brand_id}) }}">{{ model.brand_name }}</a></strong>
                    <span>{{ model.name }}</span>
                    <span></span>
                    <span class="row-actions"><a href="{{ path('app_vehicle_model_show', {id: model.id}) }}">{{ 'ui.show'|trans }}</a></span>
                </div>
            {% else %}
                <p class="empty-state">{{ 'vehicles.no_models'|trans }}</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}
